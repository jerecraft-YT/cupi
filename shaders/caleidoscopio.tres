[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform float sourceScale = 2.0;
uniform float sourceAngle : hint_range(0.0, 360.0) = 0.0;
uniform vec2 polarOffset = vec2(0.500000, 0.500000);
uniform float polarAngle : hint_range(0.0, 360.0);
uniform float segments : hint_range(2.0, 48.0, 1.0) = 6.0;
uniform vec2 sourceOffset = vec2(0.500000, 0.500000);
uniform sampler2D screen_tex_frg_49 : hint_screen_texture;



void fragment() {
// FloatParameter:7
	float n_out7p0 = sourceScale;


// FloatParameter:8
	float n_out8p0 = sourceAngle;


// FloatFunc:37
	float n_out37p0 = radians(n_out8p0);


// FloatFunc:38
	float n_out38p0 = sin(n_out37p0);


// Input:10
	vec2 n_out10p0 = UV;


// Vector2Parameter:4
	vec2 n_out4p0 = polarOffset;


// VectorOp:11
	vec2 n_out11p0 = n_out10p0 - n_out4p0;


// VectorDecompose:15
	float n_out15p0 = n_out11p0.x;
	float n_out15p1 = n_out11p0.y;


// FloatOp:19
	float n_out19p0 = atan(n_out15p1, n_out15p0);


// FloatParameter:5
	float n_out5p0 = polarAngle;


// FloatFunc:9
	float n_out9p0 = radians(n_out5p0);


// VectorOp:18
	vec2 n_out18p0 = vec2(n_out19p0) + vec2(n_out9p0);


// FloatConstant:20
	float n_out20p0 = 6.283185;


// FloatParameter:2
	float n_out2p0 = segments;


// FloatOp:21
	float n_out21p0 = n_out20p0 / n_out2p0;


// FloatOp:23
	float n_out23p0 = n_out18p0.x / n_out21p0;


// FloatFunc:24
	float n_out24p0 = floor(n_out23p0);


// FloatOp:25
	float n_out25p0 = n_out21p0 * n_out24p0;


// FloatOp:22
	float n_out22p0 = n_out18p0.x - n_out25p0;


// FloatFunc:33
	float n_out33p0 = cos(n_out22p0);


// FloatFunc:34
	float n_out34p0 = sin(n_out22p0);


// VectorCompose:32
	vec2 n_out32p0 = vec2(n_out33p0, n_out34p0);


// DotProduct:12
	float n_out12p0 = dot(vec3(n_out11p0, 0.0), vec3(n_out11p0, 0.0));


// FloatFunc:13
	float n_out13p0 = sqrt(n_out12p0);


// VectorOp:35
	vec2 n_out35p0 = n_out32p0 * vec2(n_out13p0);


// VectorDecompose:36
	float n_out36p0 = n_out35p0.x;
	float n_out36p1 = n_out35p0.y;


// FloatOp:40
	float n_out40p0 = n_out38p0 * n_out36p1;


// FloatFunc:41
	float n_out41p0 = cos(n_out37p0);


// FloatOp:42
	float n_out42p0 = n_out36p0 * n_out41p0;


// FloatOp:43
	float n_out43p0 = n_out40p0 + n_out42p0;


// FloatOp:44
	float n_out44p0 = n_out36p1 * n_out41p0;


// FloatOp:45
	float n_out45p0 = n_out38p0 * n_out36p0;


// FloatOp:46
	float n_out46p0 = n_out44p0 - n_out45p0;


// VectorCompose:39
	vec2 n_out39p0 = vec2(n_out43p0, n_out46p0);


// Vector2Parameter:6
	vec2 n_out6p0 = sourceOffset;


// VectorOp:47
	vec2 n_out47p0 = n_out39p0 + n_out6p0;


// FloatOp:48
	float n_out48p0 = n_out7p0 * n_out47p0.x;


// VectorOp:52
	vec2 n_out52p0 = vec2(n_out48p0) * vec2(n_out7p0);


// VectorOp:53
	vec2 n_out53p0 = n_out52p0 - n_out6p0;


// VectorFunc:51
	vec2 n_out51p0 = fract(n_out53p0);


	vec4 n_out49p0;
// Texture2D:49
	n_out49p0 = texture(screen_tex_frg_49, n_out51p0);


// Output:0
	COLOR.rgb = vec3(n_out49p0.xyz);


}
