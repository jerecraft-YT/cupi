code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 ColorParameter : source_color = vec4(0.000000, 1.000000, 0.000000, 1.000000);
uniform float FloatParameter = 0.0;



void fragment() {
// Input:8
	vec2 n_out8p0 = UV;


	vec4 n_out6p0;
// Texture2D:6
	n_out6p0 = texture(TEXTURE, n_out8p0);
	float n_out6p4 = n_out6p0.a;


// ColorParameter:4
	vec4 n_out4p0 = ColorParameter;


// Distance:9
	float n_out9p0 = distance(n_out6p0, n_out4p0);


// FloatParameter:5
	float n_out5p0 = FloatParameter;


	vec3 n_out3p0;
// If:3
	float n_in3p2 = 0.05000;
	if(abs(n_out9p0 - n_out4p0.x) < n_in3p2)
	{
		n_out3p0 = vec3(n_out5p0);
	}
	else if(n_out9p0 < n_out4p0.x)
	{
		n_out3p0 = vec3(n_out6p4);
	}
	else
	{
		n_out3p0 = vec3(n_out6p4);
	}


// Output:0
	COLOR.rgb = vec3(n_out6p0.xyz);
	COLOR.a = n_out3p0.x;


}
"
