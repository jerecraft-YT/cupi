[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform float frequency = 60.0;
uniform float TimeMultiplier = 5.0;
uniform float amplitude = 1.0;
uniform sampler2D screen_tex_frg_11 : hint_screen_texture;



void fragment() {
// Input:3
	vec2 n_out3p0 = SCREEN_UV;


// VectorDecompose:4
	float n_out4p0 = n_out3p0.x;
	float n_out4p1 = n_out3p0.y;


// FloatParameter:6
	float n_out6p0 = frequency;


// FloatOp:7
	float n_out7p0 = n_out4p1 * n_out6p0;


// Input:8
	float n_out8p0 = TIME;


// FloatParameter:19
	float n_out19p0 = TimeMultiplier;


// FloatOp:20
	float n_out20p0 = n_out8p0 * n_out19p0;


// FloatOp:9
	float n_out9p0 = n_out7p0 + n_out20p0;


// FloatFunc:5
	float n_out5p0 = sin(n_out9p0);


// FloatParameter:18
	float n_out18p0 = amplitude;


// FloatOp:17
	float n_in17p1 = 0.01000;
	float n_out17p0 = n_out18p0 * n_in17p1;


// FloatOp:10
	float n_out10p0 = n_out5p0 * n_out17p0;


// FloatOp:16
	float n_out16p0 = n_out4p0 + n_out10p0;


// VectorCompose:13
	vec2 n_out13p0 = vec2(n_out16p0, n_out4p1);


	vec4 n_out11p0;
// Texture2D:11
	n_out11p0 = texture(screen_tex_frg_11, n_out13p0);


// Output:0
	COLOR.rgb = vec3(n_out11p0.xyz);


}
"
