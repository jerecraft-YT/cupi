code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec2 scrollVel = vec2(0.500000, 0.000000);
uniform sampler2D tex_frg_61;
uniform vec4 ColorParameter2 : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform float radius = 0.5;
uniform vec2 center = vec2(0.500000, 0.500000);
uniform float circleAperture = 0.40000000596046;



void fragment() {
// Input:5
	vec2 n_out5p0 = UV;


// Input:50
	float n_out50p0 = TIME;


// Vector2Parameter:59
	vec2 n_out59p0 = scrollVel;


// VectorOp:51
	vec2 n_out51p0 = vec2(n_out50p0) * n_out59p0;


// VectorOp:53
	vec2 n_out53p0 = n_out5p0 + n_out51p0;


// VectorFunc:78
	vec2 n_out78p0 = fract(n_out53p0);


// Texture2D:61
	vec4 n_out61p0 = texture(tex_frg_61, n_out78p0);


// ColorParameter:62
	vec4 n_out62p0 = ColorParameter2;


// VectorOp:63
	vec3 n_out63p0 = vec3(n_out61p0.xyz) * vec3(n_out62p0.xyz);


// VectorDecompose:25
	float n_out25p0 = n_out5p0.x;
	float n_out25p1 = n_out5p0.y;


// Compare:23
	float n_in23p1 = 0.60000;
	bool n_out23p0 = n_out25p0 < n_in23p1;


// Compare:32
	float n_in32p0 = 0.90000;
	bool n_out32p0 = n_in32p0 < n_out25p0;


// Compare:24
	float n_in24p0 = 0.45000;
	bool n_out24p0 = n_in24p0 < n_out25p1;


// Compare:26
	float n_in26p0 = 0.55000;
	bool n_out26p0 = n_in26p0 > n_out25p1;


// Compare:27
	float n_in27p2 = 0.00001;
	bool n_out27p0 = (abs((n_out24p0 ? 1.0 : 0.0) - (n_out26p0 ? 1.0 : 0.0)) < n_in27p2);

// Compare:33
	bool n_out33p0 = (n_out32p0 ? 1.0 : 0.0) < (n_out27p0 ? 1.0 : 0.0);


// Compare:34
	bool n_out34p0 = (n_out23p0 ? 1.0 : 0.0) < (n_out33p0 ? 1.0 : 0.0);


// FloatParameter:13
	float n_out13p0 = radius;


// Vector2Parameter:2
	vec2 n_out2p0 = center;


// Distance:4
	float n_out4p0 = distance(n_out2p0, n_out5p0);


// Compare:9
	bool n_out9p0 = n_out13p0 > n_out4p0;


// FloatParameter:17
	float n_out17p0 = circleAperture;


// Compare:18
	bool n_out18p0 = n_out4p0 < n_out17p0;


// Compare:19
	float n_in19p2 = 0.00001;
	bool n_out19p0 = !(abs((n_out9p0 ? 1.0 : 0.0) - (n_out18p0 ? 1.0 : 0.0)) < n_in19p2);

// FloatOp:31
	float n_out31p0 = (n_out34p0 ? 1.0 : 0.0) + (n_out19p0 ? 1.0 : 0.0);


// Output:0
	COLOR.rgb = n_out63p0;
	COLOR.a = n_out31p0;


}
