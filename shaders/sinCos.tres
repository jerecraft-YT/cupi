code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 Color : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform float TimeMultiplier = 1.0;
uniform sampler2D tex_frg_30;
uniform float frequency = 0.10000000149012;
uniform float Xoffset = 0.40000000596046;



void fragment() {
// ColorParameter:21
	vec4 n_out21p0 = Color;


// Input:3
	vec2 n_out3p0 = UV;


// VectorDecompose:4
	float n_out4p0 = n_out3p0.x;
	float n_out4p1 = n_out3p0.y;


// Input:8
	float n_out8p0 = TIME;


// FloatParameter:19
	float n_out19p0 = TimeMultiplier;


// FloatOp:20
	float n_out20p0 = n_out8p0 * n_out19p0;


// FloatOp:9
	float n_out9p0 = n_out4p1 + n_out20p0;


// FloatFunc:31
	float n_out31p0 = fract(n_out9p0);


// Texture2D:30
	vec4 n_out30p0 = texture(tex_frg_30, vec2(n_out31p0));


// FloatParameter:6
	float n_out6p0 = frequency;


// FloatOp:7
	float n_out7p0 = n_out30p0.x * n_out6p0;


// FloatOp:16
	float n_out16p0 = n_out4p0 + n_out7p0;


// FloatParameter:33
	float n_out33p0 = Xoffset;


// FloatOp:34
	float n_out34p0 = n_out16p0 + n_out33p0;


// VectorCompose:13
	vec2 n_out13p0 = vec2(n_out34p0, n_out4p1);


	vec4 n_out11p0;
// Texture2D:11
	n_out11p0 = texture(TEXTURE, n_out13p0);
	float n_out11p4 = n_out11p0.a;


// FloatOp:29
	float n_out29p0 = n_out21p0.x * n_out11p0.x;


// Output:0
	COLOR.rgb = vec3(n_out29p0);
	COLOR.a = n_out11p4;


}
