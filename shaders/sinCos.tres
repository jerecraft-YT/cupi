code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 Color : source_color;
uniform float frequency = 60.0;
uniform float TimeMultiplier = 5.0;
uniform float amplitude = 1.0;



void fragment() {
// ColorParameter:21
	vec4 n_out21p0 = Color;


// Input:3
	vec2 n_out3p0 = UV;


// VectorDecompose:4
	float n_out4p0 = n_out3p0.x;
	float n_out4p1 = n_out3p0.y;


// FloatParameter:6
	float n_out6p0 = frequency;


// FloatOp:7
	float n_out7p0 = n_out4p1 * n_out6p0;


// Input:8
	float n_out8p0 = TIME;


// FloatParameter:19
	float n_out19p0 = TimeMultiplier;


// FloatOp:20
	float n_out20p0 = n_out8p0 * n_out19p0;


// FloatOp:9
	float n_out9p0 = n_out7p0 + n_out20p0;


// FloatFunc:5
	float n_out5p0 = sin(n_out9p0);


// FloatParameter:18
	float n_out18p0 = amplitude;


// FloatOp:17
	float n_in17p1 = 0.01000;
	float n_out17p0 = n_out18p0 * n_in17p1;


// FloatOp:10
	float n_out10p0 = n_out5p0 * n_out17p0;


// FloatOp:16
	float n_out16p0 = n_out4p0 + n_out10p0;


// FloatOp:22
	float n_out22p0 = n_out4p0 * n_out6p0;


// FloatOp:24
	float n_out24p0 = n_out8p0 * n_out19p0;


// FloatOp:23
	float n_out23p0 = n_out22p0 + n_out24p0;


// FloatFunc:25
	float n_out25p0 = sin(n_out23p0);


// FloatOp:26
	float n_in26p0 = 0.01000;
	float n_out26p0 = n_in26p0 * n_out18p0;


// FloatOp:27
	float n_out27p0 = n_out25p0 * n_out26p0;


// FloatOp:28
	float n_out28p0 = n_out27p0 + n_out4p1;


// VectorCompose:13
	vec2 n_out13p0 = vec2(n_out16p0, n_out28p0);


	vec4 n_out11p0;
// Texture2D:11
	n_out11p0 = texture(TEXTURE, n_out13p0);
	float n_out11p4 = n_out11p0.a;


// FloatOp:29
	float n_out29p0 = n_out21p0.x * n_out11p0.x;


// Output:0
	COLOR.rgb = vec3(n_out29p0);
	COLOR.a = n_out11p4;


}
"
