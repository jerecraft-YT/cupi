; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CUPI"
config/description="Que tan facil puede ser cantar?"
config/version="0.0.11"
run/main_scene="uid://qwgdhe76ve32"
config/quit_on_go_back=false
config/features=PackedStringArray("4.5", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://cqk3ysk80cik"

[audio]

buses/default_bus_layout="uid://byfcaghl26y8j"

[autoload]

DataGame="*res://scripts/dataGame.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
window/dpi/allow_hidpi=false
window/handheld/orientation=1
window/vsync/vsync_mode=0

[filesystem]

import/default_bus_layout="uid://byfcaghl26y8j"

[global_group]

CupiContainer=""
cupi=""
PantallaTitulo=""

[input_devices]

pointing/android/disable_scroll_deadzone=true

[physics]

2d/run_on_separate_thread=true
3d/run_on_separate_thread=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
shader_compiler/shader_cache/compress=false
shader_compiler/shader_cache/strip_debug=true
camera/depth_of_field/depth_of_field_bokeh_shape=0
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
environment/gi/use_half_resolution=false
environment/transparent_background=false
